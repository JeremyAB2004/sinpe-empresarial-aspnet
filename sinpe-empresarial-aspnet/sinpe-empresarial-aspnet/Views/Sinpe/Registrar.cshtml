@model sinpe_empresarial_aspnet.Models.Sinpe

<h2>Registrar Pago SINPE</h2>

<form asp-action="Registrar" method="post">

	<div>
		<label>Telefono Origen</label>
		<input asp-for="TelefonoOrigen" />
	</div>

	<div>
		<label>Nombre Origen</label>
		<input asp-for="NombreOrigen" />
	</div>

	<div>
		<label>Telefono Destinatorio</label>
		<input asp-for="TelefonoDestinatario" />
	</div>

	<div>
		<label>Nombre Destinatorio</label>
		<input asp-for="NombreDestinatario" />
	</div>

	<div>
		<label>Monto</label>
		<input asp-for="Monto" type="number" step="0.01" />
	</div>

	<div>
		<label>Descripcion </label>
		<input asp-for="Descripcion" />
	</div>

	<button type="submit">Registrar Pago</button>
</form>

@if (!ViewData.ModelState.IsValid)
{
	<div style="color:red;">
		@Html.ValidationSummary()
	</div>
}

