@model sinpe_empresarial_aspnet.Models.Cajas

<h2>Registrar Caja</h2>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="IdComercio" />

    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input class="form-control" asp-for="Nombre" />
        <span class="text-danger" asp-validation-for="Nombre"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Descripción</label>
        <input class="form-control" asp-for="Descripcion" />
        <span class="text-danger" asp-validation-for="Descripcion"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Teléfono SINPE</label>
        <input class="form-control" asp-for="TelefonoSINPE" />
        <span class="text-danger" asp-validation-for="TelefonoSINPE"></span>
    </div>

    <button class="btn btn-primary" type="submit">Guardar</button>
    <a class="btn btn-secondary" asp-action="Index" asp-route-idComercio="@Model.IdComercio">Cancelar</a>
</form>