@model sinpe_empresarial_aspnet.Models.Comercios

@{
    ViewBag.Title = "Detalles Comercio";
}

<h2>Detalles del Comercio</h2>

<form>

    <div class="mb-3">
        <label for="" class="form-label">Identificación</label>
        <input type="text"
               class="form-control"
               asp-for="Identificacion"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Tipo de Identificación</label>
        <input type="text"
               class="form-control"
               value="@(Model.TipoIdentificacion == 1 ? "Física" : "Jurídica")"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Nombre</label>
        <input type="text"
               class="form-control"
               asp-for="Nombre"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Tipo de Comercio</label>
        <input type="text"
               class="form-control"
               value="@(Model.TipoDeComercio == 1 ? "Restaurante" : Model.TipoDeComercio == 2 ? "Supermercado" : Model.TipoDeComercio == 3 ? "Ferretería" : "Otro")"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Teléfono</label>
        <input type="text"
               class="form-control"
               asp-for="Telefono"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Correo Electrónico</label>
        <input type="text"
               class="form-control"
               asp-for="CorreoElectronico"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Dirección</label>
        <input type="text"
               class="form-control"
               asp-for="Direccion"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Fecha de Registro</label>
        <input type="text"
               class="form-control"
               value="@Model.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Fecha de Modificación</label>
        <input type="text"
               class="form-control"
               value="@(Model.FechaDeModificacion.HasValue ? Model.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")"
               disabled />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Estado</label>
        <input type="text"
               class="form-control"
               value="@(Model.Estado ? "Activo" : "Inactivo")"
               disabled />
    </div>

    <div class="mb-3">
        <a asp-action="Edit"
           asp-route-id="@Model.IdComercio"
           class="btn btn-warning"
           role="button">Editar</a>

        <a asp-action="Index"
           class="btn btn-danger"
           role="button">Volver</a>
    </div>

</form>