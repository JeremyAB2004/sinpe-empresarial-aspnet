@model sinpe_empresarial_aspnet.Models.Comercios

@{
    ViewBag.Title = "Registrar Comercio";
}

<h2>Registrar Comercio</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
    <a asp-action="Index"
       class="btn btn-secondary"
       role="button">Volver al listado</a>
}

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label for="" class="form-label">Identificación</label>
        <input type="text"
               class="form-control"
               placeholder="Ingrese la identificación"
               asp-for="Identificacion" />
        <span asp-validation-for="Identificacion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Tipo de Identificación</label>
        <select class="form-control" asp-for="TipoIdentificacion">
            <option value="">-- Seleccione --</option>
            <option value="1">Física</option>
            <option value="2">Jurídica</option>
        </select>
        <span asp-validation-for="TipoIdentificacion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Nombre</label>
        <input type="text"
               class="form-control"
               placeholder="Ingrese el nombre"
               asp-for="Nombre" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Tipo de Comercio</label>
        <select class="form-control" asp-for="TipoDeComercio">
            <option value="">-- Seleccione --</option>
            <option value="1">Restaurante</option>
            <option value="2">Supermercado</option>
            <option value="3">Ferretería</option>
            <option value="4">Otro</option>
        </select>
        <span asp-validation-for="TipoDeComercio" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Teléfono</label>
        <input type="text"
               class="form-control"
               placeholder="Ingrese el teléfono"
               asp-for="Telefono" />
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Correo Electrónico</label>
        <input type="text"
               class="form-control"
               placeholder="Ingrese el correo electrónico"
               asp-for="CorreoElectronico" />
        <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Dirección</label>
        <input type="text"
               class="form-control"
               placeholder="Ingrese la dirección"
               asp-for="Direccion" />
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <a asp-action="Index"
           class="btn btn-danger"
           role="button">Cancelar</a>

        <button type="submit"
                class="btn btn-primary">
            Registrar
        </button>
    </div>

</form>